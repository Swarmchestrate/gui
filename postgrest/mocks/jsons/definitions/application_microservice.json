{
    "description": "Application description table storing all metadata, specs, relationships, behaviours, resource requirements, and QoS goals.",
    "required": ["id", "container_image"],
    "properties": {
        "id": {
            "description": "Note:\nThis is a Primary Key.<pk/>",
            "format": "integer",
            "type": "integer"
        },
        "name": {
            "format": "character varying",
            "type": "string"
        },
        "application_id": {
            "description": "Note:\nThis is a Foreign Key to `application_new.application_id`.<fk table='application_new' column='application_id'/>",
            "format": "integer",
            "type": "integer"
        },
        "container_image": {
            "description": "OCI-compliant container image (mandatory parameter).",
            "format": "character varying",
            "maxLength": 500,
            "type": "string"
        },
        "commands": {
            "description": "List of startup commands.",
            "format": "text[]",
            "items": { "type": "string" },
            "type": "array"
        },
        "arguments": {
            "description": "Arguments passed to the application container.",
            "format": "text[]",
            "items": { "type": "string" },
            "type": "array"
        },
        "behaviour_id": {
            "description": "Note:\nThis is a Foreign Key to `application_behaviour.behaviour_id`.<fk table='application_behaviour' column='behaviour_id'/>",
            "format": "integer",
            "type": "integer"
        },
        "location_id": {
            "description": "Note:\nThis is a Foreign Key to `locality.locality_id`.<fk table='locality' column='locality_id'/>",
            "format": "integer",
            "type": "integer"
        },
        "min_cpu": {
            "description": "Minimum required CPU.",
            "format": "integer",
            "type": "integer"
        },
        "max_cpu": {
            "description": "Maximum allowed CPU.",
            "format": "integer",
            "type": "integer"
        },
        "min_memory_gb": {
            "description": "Minimum required memory in GB.",
            "format": "integer",
            "type": "integer"
        },
        "max_memory_gb": {
            "description": "Maximum allowed memory in GB.",
            "format": "integer",
            "type": "integer"
        },
        "min_gpu": {
            "format": "integer",
            "type": "integer"
        },
        "max_gpu": {
            "format": "integer",
            "type": "integer"
        },
        "min_disk_size": {
            "description": "Minimum required disk size in GB.",
            "format": "integer",
            "type": "integer"
        },
        "max_disk_size": {
            "description": "Maximum allowed disk size in GB.",
            "format": "integer",
            "type": "integer"
        },
        "min_network_bandwidth_mbps": {
            "description": "Minimum required network bandwidth in MB/s.",
            "format": "text",
            "type": "string"
        },
        "max_network_bandwidth_mbps": {
            "description": "Maximum allowed network bandwidth in MB/s.",
            "format": "text",
            "type": "string"
        },
        "min_response_time_ms": {
            "format": "numeric",
            "type": "number"
        },
        "max_response_time_ms": {
            "format": "numeric",
            "type": "number"
        },
        "num_instances": {
            "description": "Number of instances required.",
            "format": "integer",
            "type": "integer"
        },
        "instance_type": {
            "description": "Type of instance: General or Optimised (CPU/RAM/Storage/GPU).",
            "format": "character varying",
            "maxLength": 100,
            "type": "string"
        },
        "energy_type": {
            "description": "Energy type preference (Green, Brown, Mix).",
            "format": "character varying",
            "maxLength": 50,
            "type": "string"
        },
        "max_price": {
            "description": "Maximum price user is willing to pay for resource unit.",
            "format": "numeric",
            "type": "number"
        },
        "pref_capacity_provider": {
            "description": "Preferred capacity provider (e.g., ACME Corp).",
            "format": "character varying",
            "maxLength": 255,
            "type": "string"
        },
        "pref_resource_type": {
            "description": "Preferred type of resource (Cloud/Edge).",
            "format": "character varying",
            "maxLength": 50,
            "type": "string"
        },
        "pref_provider_type": {
            "description": "Preferred provider type (Public/Private).",
            "format": "character varying",
            "maxLength": 50,
            "type": "string"
        }
    },
    "type": "object"
}
